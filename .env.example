# Gestia AI Business Assistant — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Never commit the actual .env file to version control.

# ─────────────────────────────────────────────────────────────────────────────
# Option A: Google AI Studio (recommended for local development without GCP)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Option B: Vertex AI (recommended for production / GCP environments)
# These are auto-detected when running `gcloud auth application-default login`
# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=True

# ─────────────────────────────────────────────────────────────────────────────
# Future: Gestia REST API integration
# (Leave blank until the real integration is implemented)
# ─────────────────────────────────────────────────────────────────────────────
# GESTIA_API_BASE_URL=http://localhost:8080
# GESTIA_API_KEY=your-gestia-api-key
